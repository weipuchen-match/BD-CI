<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>BNI 華榮分會 — 商務開發與企業形象組</title>
<meta name="description" content="BNI 新北西B區 華榮分會 — 商務開發與企業形象組引薦指南"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@600;700;800;900&family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet"/>
<style>
/* ════════ RESET & ROOT ════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0a0b0f;--bg2:#111318;--bg3:#161820;
  --accent:#6c63ff;--accent2:#a78bfa;
  --green:#22c55e;--blue:#3b82f6;--orange:#f97316;
  --purple:#a855f7;--pink:#ec4899;--teal:#14b8a6;--red:#ef4444;
  --white:#f1f2f6;--muted:#9ca3af;--dark:#1a1c23;--dark2:#4b5563;
  --lbg:#ffffff;--lbg2:#f4f5f8;
  --sidebar:260px;--r:16px;--rs:10px;--rx:6px;
  --f:'Inter','Noto Sans TC',system-ui,sans-serif;
  --fd:'Outfit','Noto Sans TC',system-ui,sans-serif;
}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:var(--f);background:var(--bg);color:var(--white);display:flex;min-height:100vh;overflow-x:hidden}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:#2a2d3a;border-radius:3px}

/* ════════ LAYOUT ════════ */
.sidebar{
  position:fixed;top:0;left:0;
  width:var(--sidebar);height:100vh;
  background:#0d0e14;border-right:1px solid rgba(255,255,255,.06);
  display:flex;flex-direction:column;
  padding:20px 0;z-index:200;
  transition:transform .3s cubic-bezier(.4,0,.2,1);
  overflow-y:auto;overflow-x:hidden;
}
.sidebar-logo{display:flex;align-items:center;gap:10px;padding:0 16px 20px;border-bottom:1px solid rgba(255,255,255,.06);margin-bottom:16px}
.logo-mark{width:38px;height:38px;background:linear-gradient(135deg,var(--accent),var(--accent2));border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:900;font-size:13px;color:#fff;flex-shrink:0}
.logo-text{display:flex;flex-direction:column;min-width:0}
.logo-chapter{font-size:11.5px;font-weight:700;color:var(--white);line-height:1.4;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.logo-sub{font-size:9.5px;color:var(--muted);line-height:1.4}
.nav-label{font-size:9.5px;font-weight:700;letter-spacing:1.5px;color:var(--muted);padding:0 16px 6px;text-transform:uppercase}
.nav-list{list-style:none;padding:0 8px}
.nav-link{display:flex;align-items:center;gap:8px;padding:7px 10px;border-radius:var(--rx);font-size:12px;font-weight:500;color:var(--muted);text-decoration:none;transition:all .18s;margin-bottom:1px;line-height:1.3}
.nav-link:hover{color:var(--white);background:rgba(255,255,255,.05)}
.nav-link.active{color:var(--white);background:rgba(108,99,255,.22)}
.nav-icon{font-size:14px;flex-shrink:0}
.nav-text{display:flex;flex-direction:column;gap:0}
.nav-text .zh{font-size:12px;font-weight:600;color:inherit}
.nav-text .en{font-size:9.5px;opacity:.6;font-weight:400}
.sidebar-footer{margin-top:auto;padding:16px;border-top:1px solid rgba(255,255,255,.06)}
.sidebar-tag{font-size:10.5px;font-style:italic;color:var(--accent2);opacity:.7}

/* ── Hamburger ── */
.hamburger{
  display:none;position:fixed;top:14px;left:14px;z-index:300;
  background:var(--bg2);border:1px solid rgba(255,255,255,.12);
  border-radius:8px;padding:9px;cursor:pointer;
  flex-direction:column;gap:4px;
}
.hamburger span{display:block;width:20px;height:2px;background:var(--white);border-radius:2px;transition:all .25s}
.hamburger.open span:nth-child(1){transform:translateY(6px) rotate(45deg)}
.hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0)}
.hamburger.open span:nth-child(3){transform:translateY(-6px) rotate(-45deg)}

/* ── Overlay for mobile sidebar ── */
.sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:150;backdrop-filter:blur(2px)}
.sidebar-overlay.show{display:block}

.main{margin-left:var(--sidebar);flex:1;min-width:0}

/* ════════ SECTIONS ════════ */
.section{min-height:100vh;padding:72px 56px;position:relative;background:var(--bg)}
.section.dark{background:var(--bg2)}
.inner{max-width:1080px;margin:0 auto}

/* ── Bilingual helpers ── */
.bi-en{display:block;font-size:.82em;color:var(--muted);font-style:italic;margin-top:2px;font-weight:400}
.title-en{display:block;font-size:.6em;font-weight:500;color:var(--muted);margin-top:4px;letter-spacing:.2px}
.desc-en{font-size:.88em;opacity:.65;font-style:italic;display:block;margin-top:4px}
.hl-en{font-size:.72em;color:var(--muted);font-weight:400;font-style:italic;margin-left:3px}
.pain-en{display:block;font-size:.86em;opacity:.65;font-style:italic;margin-top:2px}
.qen{display:block;margin-top:6px;font-size:.88em;opacity:.75}

/* ── Section header ── */
.sec-head{margin-bottom:40px}
.sec-tag{display:inline-flex;font-size:10.5px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--accent2);background:rgba(108,99,255,.12);border:1px solid rgba(108,99,255,.28);padding:3px 11px;border-radius:20px;margin-bottom:14px}
.sec-title{font-family:var(--fd);font-size:clamp(24px,3.5vw,40px);font-weight:800;line-height:1.15;color:var(--white);margin-bottom:12px}
.sec-desc{font-size:14px;color:var(--muted);line-height:1.7;max-width:680px}

/* ════════ COVER ════════ */
#s-cover{display:flex;align-items:center;justify-content:center;text-align:center;min-height:100vh;overflow:hidden;background:#050609;padding:40px 24px}
.cover-bg{position:absolute;inset:0;pointer-events:none}
.orb{position:absolute;border-radius:50%;filter:blur(110px);opacity:.45}
.orb1{width:500px;height:500px;background:radial-gradient(circle,#6c63ff55,transparent);top:-150px;left:-80px;animation:float 8s ease-in-out infinite}
.orb2{width:420px;height:420px;background:radial-gradient(circle,#a78bfa44,transparent);bottom:-120px;right:-40px;animation:float 10s ease-in-out infinite reverse}
.orb3{width:300px;height:300px;background:radial-gradient(circle,#14b8a633,transparent);top:40%;left:50%;transform:translate(-50%,-50%);animation:pulse 6s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0) scale(1)}50%{transform:translateY(-30px) scale(1.04)}}
@keyframes pulse{0%,100%{opacity:.3;transform:translate(-50%,-50%) scale(1)}50%{opacity:.5;transform:translate(-50%,-50%) scale(1.12)}}
.cover-wrap{position:relative;z-index:2;max-width:780px;width:100%}
.cover-eye{display:inline-flex;align-items:center;gap:7px;font-size:11.5px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent2);margin-bottom:24px;padding:5px 14px;background:rgba(108,99,255,.1);border:1px solid rgba(108,99,255,.22);border-radius:30px}
.eye-dot{width:5px;height:5px;background:var(--green);border-radius:50%;animation:blink 2s ease-in-out infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.25}}
.cover-title{font-family:var(--fd);font-size:clamp(32px,6vw,68px);font-weight:900;line-height:1.08;color:var(--white);margin-bottom:16px}
.cover-sub{font-size:clamp(16px,2.5vw,28px);font-weight:700;color:var(--muted);display:block}
.cover-accent{background:linear-gradient(135deg,var(--accent),var(--accent2),var(--teal));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.cover-desc{font-size:clamp(14px,1.5vw,17px);color:var(--muted);margin-bottom:36px;font-weight:500;line-height:1.7}
.cover-desc .en{font-size:.82em;opacity:.65;display:block;margin-top:4px;font-style:italic}
.cover-stats{display:flex;align-items:center;justify-content:center;gap:24px;margin-bottom:36px;flex-wrap:wrap}
.stat{text-align:center}
.stat-n{display:block;font-family:var(--fd);font-size:clamp(24px,3vw,34px);font-weight:800;color:var(--white);line-height:1}
.stat-l{font-size:11px;color:var(--muted);margin-top:3px;text-transform:uppercase;letter-spacing:.8px}
.stat-div{width:1px;height:40px;background:rgba(255,255,255,.1)}
.cover-cta{display:inline-block;padding:14px 32px;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;font-size:14px;font-weight:700;border-radius:50px;text-decoration:none;letter-spacing:.4px;transition:all .3s;box-shadow:0 8px 28px rgba(108,99,255,.38)}
.cover-cta:hover{transform:translateY(-3px);box-shadow:0 14px 36px rgba(108,99,255,.52)}

/* ════════ PHOTO UPLOAD SYSTEM ════════ */
.photo-wrap{position:relative;display:inline-block;cursor:pointer;margin-bottom:16px}
.photo-wrap:hover .photo-overlay{opacity:1}
.photo-overlay{
  position:absolute;inset:0;border-radius:22px;
  background:rgba(0,0,0,.65);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  opacity:0;transition:opacity .22s;
  gap:4px;
}
.photo-overlay span{font-size:18px}
.photo-overlay p{font-size:10px;color:#fff;font-weight:600;text-align:center;line-height:1.3}
.photo-overlay .remove{position:absolute;top:6px;right:6px;width:20px;height:20px;background:rgba(239,68,68,.9);border:none;border-radius:50%;color:#fff;font-size:12px;cursor:pointer;display:none;align-items:center;justify-content:center;font-weight:700}
.photo-wrap.has-photo .photo-overlay .remove{display:flex}
.photo-input{display:none}

/* Profile page avatar */
.p-avatar{
  width:110px;height:110px;border-radius:22px;
  display:flex;align-items:center;justify-content:center;
  font-family:var(--fd);font-weight:900;font-size:30px;color:#fff;
  box-shadow:0 10px 36px rgba(0,0,0,.3);transition:all .2s;overflow:hidden;
}
.p-avatar img{width:100%;height:100%;object-fit:cover;object-position:top center}

/* Overview card avatar */
.mc-av{
  width:52px;height:52px;border-radius:13px;
  display:flex;align-items:center;justify-content:center;
  font-family:var(--fd);font-weight:800;font-size:16px;color:#fff;
  margin-bottom:12px;overflow:hidden;flex-shrink:0;
}
.mc-av img{width:100%;height:100%;object-fit:cover;object-position:top center}

/* Table small avatar */
.t-av{width:44px;height:44px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;color:#fff;overflow:hidden;flex-shrink:0;margin:6px 0}
.t-av img{width:100%;height:100%;object-fit:cover;object-position:top}

/* Avatar color classes */
.av-green{background:linear-gradient(135deg,#16a34a,#22c55e)}
.av-blue{background:linear-gradient(135deg,#1d4ed8,#3b82f6)}
.av-orange{background:linear-gradient(135deg,#c2410c,#f97316)}
.av-purple{background:linear-gradient(135deg,#7e22ce,#a855f7)}
.av-pink{background:linear-gradient(135deg,#be185d,#ec4899)}
.av-teal{background:linear-gradient(135deg,#0f766e,#14b8a6)}
.av-red{background:linear-gradient(135deg,#b91c1c,#ef4444)}
.av-gray{background:linear-gradient(135deg,#374151,#6b7280)}

/* ── Toast ── */
.toast{
  position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(20px);
  background:#1e2030;border:1px solid rgba(108,99,255,.35);
  padding:10px 20px;border-radius:50px;
  font-size:13px;font-weight:600;color:var(--white);
  opacity:0;transition:all .3s;pointer-events:none;z-index:9999;white-space:nowrap;
}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ════════ TEAM OVERVIEW GRID ════════ */
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.mem-card{
  background:var(--bg3);border:1px solid rgba(255,255,255,.06);
  border-radius:var(--r);padding:20px 16px;
  text-decoration:none;color:inherit;
  transition:all .25s;cursor:pointer;position:relative;overflow:hidden;
}
.mem-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(108,99,255,.06),transparent);opacity:0;transition:opacity .25s}
.mem-card:hover{border-color:rgba(108,99,255,.3);transform:translateY(-4px);box-shadow:0 12px 36px rgba(0,0,0,.4)}
.mem-card:hover::before{opacity:1}
.mem-card.dimmed{opacity:.5;cursor:default}
.mem-card.dimmed:hover{transform:none;box-shadow:none}
.mc-num{font-size:10.5px;font-weight:700;letter-spacing:1px;color:var(--muted);margin-bottom:10px}
.mc-name{font-size:13px;font-weight:700;color:var(--white);margin-bottom:2px;line-height:1.35}
.mc-name-en{display:block;font-size:10.5px;font-weight:500;color:var(--muted);margin-top:1px}
.mc-role{font-size:11px;color:var(--muted);margin-bottom:3px;line-height:1.4}
.mc-co{font-size:10.5px;color:var(--accent2);margin-bottom:8px}
.mc-tag{font-size:10px;color:var(--muted);padding:3px 7px;background:rgba(255,255,255,.04);border-radius:var(--rx);border:1px solid rgba(255,255,255,.06);display:inline-block}

/* ════════ REFERRAL MATRIX ════════ */
.matrix-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}
.mx-card{
  background:var(--lbg);border-radius:var(--r);padding:22px;
  border:1px solid rgba(0,0,0,.07);transition:all .25s;
  position:relative;overflow:hidden;
}
.mx-card::before{content:'';position:absolute;top:0;left:0;width:4px;height:100%;background:linear-gradient(180deg,var(--accent),var(--accent2))}
.mx-card:hover{transform:translateY(-3px);box-shadow:0 14px 42px rgba(0,0,0,.12)}
.mx-trigger{display:flex;align-items:flex-start;gap:10px;margin-bottom:12px}
.mx-icon{font-size:24px;flex-shrink:0;line-height:1}
.mx-trigger-lbl{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--dark2);margin-bottom:3px}
.mx-trigger-type{font-size:14px;font-weight:700;color:var(--dark);line-height:1.3}
.mx-pain{font-size:12px;color:var(--dark2);background:#f7f8ff;border-radius:var(--rx);padding:8px 10px;margin-bottom:10px;line-height:1.5}
.mx-pain-lbl{font-weight:700;color:#d97706;margin-right:3px}
.mx-refer{display:flex;align-items:center;gap:7px;font-size:12.5px;color:var(--dark);margin-bottom:10px}
.mx-refer strong{color:var(--accent)}
.mx-badge{font-size:9.5px;font-weight:800;letter-spacing:.8px;text-transform:uppercase;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;padding:2px 8px;border-radius:4px;flex-shrink:0}
.mx-hook{font-size:11.5px;color:var(--dark2);background:linear-gradient(135deg,#f0f2ff,#fdf4ff);border-left:3px solid var(--accent);padding:9px 11px;border-radius:0 var(--rx) var(--rx) 0;line-height:1.6}
.hook-lbl{font-weight:700;color:var(--accent);margin-right:3px}

/* ════════ ASKS & GIVES TABLE ════════ */
.table-wrap{overflow-x:auto;border-radius:var(--r);border:1px solid rgba(255,255,255,.07)}
.cheat{width:100%;border-collapse:collapse;font-size:12.5px;min-width:680px}
.cheat thead tr{background:rgba(108,99,255,.12)}
.cheat th{padding:14px 18px;text-align:left;font-size:11.5px;font-weight:700;letter-spacing:.4px;color:var(--accent2);border-bottom:1px solid rgba(255,255,255,.07)}
.th-sub{display:block;font-size:10px;font-weight:500;color:var(--muted);margin-top:2px;white-space:normal}
.cheat tbody tr{border-bottom:1px solid rgba(255,255,255,.05);transition:background .18s}
.cheat tbody tr:hover{background:rgba(255,255,255,.03)}
.cheat tbody tr:last-child{border-bottom:none}
.cheat td{padding:16px 18px;vertical-align:top;color:var(--muted);line-height:1.6}
.col-m{width:180px;min-width:160px}
.col-a,.col-g{min-width:220px}
.ct-badge{display:inline-block;font-size:9.5px;font-weight:800;padding:2px 7px;border-radius:4px;color:#fff;margin-bottom:4px}
.ct-name{font-size:13.5px;color:var(--white);font-weight:700;display:block;margin-top:2px}
.ct-role{font-size:11px;color:var(--muted);margin-top:1px}
.cheat ul{list-style:none;padding:0}
.cheat ul li{font-size:12px;color:var(--muted);padding:3px 0;display:flex;gap:5px}
.cheat ul li::before{content:'•';color:var(--accent2);font-size:13px;flex-shrink:0;line-height:1.5}

/* ════════ TARGET MARKETS ════════ */
.grid-tg{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}
.tg-card{background:var(--lbg);border-radius:var(--r);padding:24px 20px;border:1px solid rgba(0,0,0,.07);transition:all .28s}
.tg-card:hover{transform:translateY(-4px);box-shadow:0 18px 50px rgba(108,99,255,.12);border-color:rgba(108,99,255,.22)}
.tg-icon{font-size:30px;margin-bottom:10px;display:block}
.tg-num{font-size:10.5px;font-weight:800;letter-spacing:1.5px;color:var(--accent);margin-bottom:7px}
.tg-title{font-family:var(--fd);font-size:14.5px;font-weight:700;color:var(--dark);margin-bottom:8px;line-height:1.3}
.tg-desc{font-size:12px;color:var(--dark2);line-height:1.6}

/* ════════ MEMBER PROFILE ════════ */
.profile-grid{display:grid;grid-template-columns:260px 1fr;gap:52px;align-items:start}
.profile-left{position:sticky;top:32px}
.p-num{font-size:10.5px;font-weight:800;letter-spacing:2px;color:var(--muted);margin-bottom:14px}
.p-name{font-family:var(--fd);font-size:19px;font-weight:800;color:var(--white);line-height:1.3;margin-bottom:3px}
.p-name-en{display:block;font-size:12.5px;font-weight:500;color:var(--muted);margin-top:2px}
.p-role{font-size:12.5px;font-weight:600;color:var(--accent2);margin-bottom:5px;line-height:1.4}
.p-co{font-size:11.5px;color:var(--muted);margin-bottom:16px}
.p-contact{margin-bottom:16px}
.p-contact-item{font-size:11.5px;color:var(--muted);margin-bottom:4px}
.p-clients-lbl{font-size:9.5px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:7px}
.p-tags{display:flex;flex-wrap:wrap;gap:5px}
.p-tags span{font-size:10.5px;font-weight:600;color:var(--white);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);border-radius:4px;padding:2px 7px}
.p-tagline{font-size:15px;color:var(--muted);line-height:1.65;margin-bottom:28px;border-left:3px solid var(--accent);padding-left:14px}
.p-highlights{margin-bottom:28px}
.p-hi{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid rgba(255,255,255,.06)}
.p-hi:last-child{border-bottom:none}
.hi-icon{font-size:20px;flex-shrink:0;margin-top:1px}
.p-hi strong{display:block;font-size:13.5px;font-weight:700;color:var(--white);margin-bottom:4px}
.p-hi p{font-size:12.5px;color:var(--muted);line-height:1.65}
.p-quote{background:rgba(108,99,255,.08);border:1px solid rgba(108,99,255,.2);border-left:4px solid var(--accent);border-radius:0 var(--rs) var(--rs) 0;padding:14px 18px;font-size:13px;color:var(--accent2);font-style:italic;line-height:1.7;margin-bottom:24px}
.tier-box{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:var(--r);padding:20px}
.tier-title{font-size:10.5px;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.tier-row{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.05);align-items:flex-start}
.tier-row:last-child{border-bottom:none;padding-bottom:0}
.tier-badge{font-size:9.5px;font-weight:800;letter-spacing:.4px;text-transform:uppercase;padding:3px 9px;border-radius:4px;flex-shrink:0;white-space:nowrap;margin-top:1px}
.t-gen{background:rgba(34,197,94,.15);color:#22c55e;border:1px solid rgba(34,197,94,.3)}
.t-ide{background:rgba(59,130,246,.15);color:#60a5fa;border:1px solid rgba(59,130,246,.3)}
.t-drm{background:rgba(168,85,247,.15);color:#c084fc;border:1px solid rgba(168,85,247,.3)}
.tier-text{font-size:12px;color:var(--muted);line-height:1.6}
.own-brands{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:var(--r);padding:18px 20px;margin-bottom:20px}
