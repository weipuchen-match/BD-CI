<script>
(function(){
'use strict';

/* ══ PHOTO UPLOAD & LOCALSTORAGE ══
   Photos are stored as base64 in localStorage.
   Key format: bni-photo-{memberId}
   Applied to: profile avatar, overview card avatar, table small avatar
*/
const MEMBERS=['patrick','jiajun','mason','terry','sage','show','fei'];
const LS_KEY=id=>'bni-photo-'+id;

function setPhoto(id,dataUrl){
  // Profile large avatar
  const pv=document.getElementById('pv-'+id);
  if(pv){pv.innerHTML='<img src="'+dataUrl+'" alt="'+id+'"/>';pv.style.background='none';pv.style.fontSize='0';}
  // Overview card avatar
  const mc=document.getElementById('mc-'+id);
  if(mc){mc.innerHTML='<img src="'+dataUrl+'" alt="'+id+'"/>';mc.style.background='none';mc.style.fontSize='0';}
  // Table avatar
  const ta=document.getElementById('ta-'+id);
  if(ta){ta.innerHTML='<img src="'+dataUrl+'" alt="'+id+'"/>';ta.style.background='none';ta.style.fontSize='0';}
  // Show remove button on photo-wrap
  const wrap=document.querySelector('.photo-wrap[data-member="'+id+'"]');
  if(wrap){wrap.classList.add('has-photo');}
}

function clearPhoto(id){
  localStorage.removeItem(LS_KEY(id));
  // Restore defaults
  const defaults={patrick:'PW',jiajun:'JZ',mason:'MJ',terry:'TH',sage:'SH',show:'SW',fei:'FL'};
  const colors={patrick:'av-green',jiajun:'av-blue',mason:'av-orange',terry:'av-purple',sage:'av-pink',show:'av-teal',fei:'av-red'};
  [['pv-','p-avatar'],['mc-','mc-av'],['ta-','t-av']].forEach(([pfx,cls])=>{
    const el=document.getElementById(pfx+id);
    if(el){
      el.innerHTML=defaults[id];
      el.style.background='';
      el.style.fontSize='';
      // Re-apply color class (it's already in HTML but check)
    }
  });
  const wrap=document.querySelector('.photo-wrap[data-member="'+id+'"]');
  if(wrap)wrap.classList.remove('has-photo');
  showToast('已移除照片 Photo removed ✓');
}

function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2800);
}

// Load stored photos on page init
MEMBERS.forEach(id=>{
  const stored=localStorage.getItem(LS_KEY(id));
  if(stored)setPhoto(id,stored);
});

// Wire up photo-wrap clicks → file input
document.querySelectorAll('.photo-wrap').forEach(wrap=>{
  const id=wrap.dataset.member;
  const input=wrap.querySelector('.photo-input');
  const removeBtn=wrap.querySelector('.remove');

  // Click wrap → open file picker (but not if clicking remove btn)
  wrap.addEventListener('click',e=>{
    if(e.target===removeBtn||e.target.closest('.remove'))return;
    input.click();
  });

  // File selected
  input.addEventListener('change',e=>{
    const file=e.target.files[0];
    if(!file)return;
    const reader=new FileReader();
    reader.onload=ev=>{
      const dataUrl=ev.target.result;
      try{localStorage.setItem(LS_KEY(id),dataUrl);}catch(err){showToast('⚠️ 儲存空間不足，但照片已顯示 (Storage full, photo shown but not saved)');
      }
      setPhoto(id,dataUrl);
      showToast('✅ '+id+' 的照片已上傳並儲存 Photo uploaded &amp; saved!');
    };
    reader.readAsDataURL(file);
    input.value='';
  });

  // Remove button
  if(removeBtn){
    removeBtn.addEventListener('click',e=>{
      e.stopPropagation();
      clearPhoto(id);
    });
  }
});

/* ══ SIDEBAR ══ */
const sidebar=document.getElementById('sidebar');
const hamburger=document.getElementById('hamburger');
const overlay=document.getElementById('overlay');

function openSidebar(){sidebar.classList.add('open');overlay.classList.add('show');hamburger.classList.add('open');}
function closeSidebar(){sidebar.classList.remove('open');overlay.classList.remove('show');hamburger.classList.remove('open');}

hamburger.addEventListener('click',()=>sidebar.classList.contains('open')?closeSidebar():openSidebar());
overlay.addEventListener('click',closeSidebar);

/* ══ NAV LINKS ══ */
const navLinks=document.querySelectorAll('.nav-link');
navLinks.forEach(link=>{
  link.addEventListener('click',e=>{
    const href=link.getAttribute('href');
    if(href&&href.startsWith('#')){
      e.preventDefault();
      const target=document.querySelector(href);
      if(target){target.scrollIntoView({behavior:'smooth',block:'start'});}
      closeSidebar();
    }
  });
});

/* ══ ACTIVE NAV (IntersectionObserver) ══ */
const sections=document.querySelectorAll('section[id]');
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      const id=e.target.id;
      navLinks.forEach(l=>l.classList.toggle('active',l.getAttribute('href')==='#'+id));
    }
  });
},{threshold:0.3});
sections.forEach(s=>io.observe(s));

/* ══ SCROLL PROGRESS + BACK-TO-TOP ══ */
const prog=document.getElementById('prog');
const backTop=document.getElementById('backTop');
window.addEventListener('scroll',()=>{
  const y=window.scrollY,h=document.documentElement.scrollHeight-window.innerHeight;
  prog.style.setProperty('--p',(h>0?(y/h*100).toFixed(1):0)+'%');
  backTop.classList.toggle('show',y>500);
},{passive:true});
backTop.addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));

/* ══ COVER CTA ══ */
const cta=document.getElementById('ctaBtn');
if(cta)cta.addEventListener('click',e=>{e.preventDefault();const t=document.getElementById('s-overview');if(t)t.scrollIntoView({behavior:'smooth',block:'start'});});

/* ══ OVERVIEW CARD NAVIGATION ══ */
['patrick','jiajun','mason','terry','sage','show','fei'].forEach(id=>{
